    "72": "288px",
    "80": "320px",
    "96": "384px"
  },

  "borderRadius": {
    "none": "0px",
    "sm": "calc(0.75rem - 4px)",
    "default": "0.75rem",
    "md": "calc(0.75rem - 2px)",
    "lg": "0.75rem",
    "xl": "calc(0.75rem + 4px)",
    "2xl": "calc(0.75rem + 8px)",
    "3xl": "1.5rem",
    "full": "9999px"
  },

  "shadows": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "default": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
    "xl": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)",
    "2xl": "0 25px 50px -12px rgb(0 0 0 / 0.25)",
    "inner": "inset 0 2px 4px 0 rgb(0 0 0 / 0.05)"
  },

  "glows": {
    "cyan": {
      "light": "0 0 20px hsla(185, 100%, 40%, 0.3)",
      "dark": "0 0 30px hsla(185, 100%, 50%, 0.4)"
    },
    "purple": {
      "light": "0 0 20px hsla(280, 70%, 55%, 0.3)",
      "dark": "0 0 30px hsla(280, 100%, 65%, 0.4)"
    },
    "intense": {
      "light": "0 0 40px hsla(185, 100%, 40%, 0.4), 0 0 80px hsla(185, 100%, 40%, 0.2)",
      "dark": "0 0 60px hsla(185, 100%, 50%, 0.6), 0 0 120px hsla(185, 100%, 50%, 0.3)"
    }
  },

  "gradients": {
    "cyber": {
      "light": "linear-gradient(135deg, hsla(185, 100%, 40%, 0.1), hsla(280, 70%, 55%, 0.1))",
      "dark": "linear-gradient(135deg, hsla(185, 100%, 50%, 0.15), hsla(280, 100%, 65%, 0.15))"
    },
    "neon": {
      "light": "linear-gradient(90deg, hsl(185, 100%, 40%), hsl(280, 70%, 55%))",
      "dark": "linear-gradient(90deg, hsl(185, 100%, 50%), hsl(280, 100%, 65%))"
    },
    "card": {
      "light": "linear-gradient(180deg, hsl(0, 0%, 100%), hsl(220, 15%, 98%))",
      "dark": "linear-gradient(180deg, hsl(220, 20%, 10%), hsl(220, 20%, 6%))"
    },
    "primary": "linear-gradient(135deg, #00B3CC, #00D4FF)",
    "accent": "linear-gradient(135deg, #9B4DCA, #B266FF)",
    "success": "linear-gradient(135deg, #1F9D55, #22C55E)",
    "warning": "linear-gradient(135deg, #D97706, #F59E0B)",
    "error": "linear-gradient(135deg, #DC2626, #EF4444)"
  },

  "animations": {
    "durations": {
      "fast": "150ms",
      "normal": "200ms",
      "slow": "300ms",
      "slower": "500ms"
    },
    "easings": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "inOut": "cubic-bezier(0.4, 0, 0.2, 1)",
      "bounce": "cubic-bezier(0.68, -0.55, 0.265, 1.55)"
    },
    "keyframes": {
      "fadeIn": {
        "from": { "opacity": 0 },
        "to": { "opacity": 1 }
      },
      "slideInFromTop": {
        "from": { "transform": "translateY(-10px)", "opacity": 0 },
        "to": { "transform": "translateY(0)", "opacity": 1 }
      },
      "slideInFromBottom": {
        "from": { "transform": "translateY(10px)", "opacity": 0 },
        "to": { "transform": "translateY(0)", "opacity": 1 }
      },
      "scaleIn": {
        "from": { "transform": "scale(0.95)", "opacity": 0 },
        "to": { "transform": "scale(1)", "opacity": 1 }
      },
      "pulseGlow": {
        "0%, 100%": { "boxShadow": "0 0 20px hsla(185, 100%, 50%, 0.4)" },
        "50%": { "boxShadow": "0 0 40px hsla(185, 100%, 50%, 0.7), 0 0 60px hsla(185, 100%, 50%, 0.4)" }
      },
      "float": {
        "0%, 100%": { "transform": "translateY(0)" },
        "50%": { "transform": "translateY(-10px)" }
      },
      "shimmer": {
        "0%": { "backgroundPosition": "-200% 0" },
        "100%": { "backgroundPosition": "200% 0" }
      }
    }
  },

  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },

  "container": {
    "center": true,
    "padding": {
      "default": "1rem",
      "sm": "2rem",
      "lg": "4rem",
      "xl": "5rem",
      "2xl": "6rem"
    },
    "maxWidth": "1400px"
  },

  "components": {
    "button": {
      "variants": {
        "default": {
          "background": "primary",
          "foreground": "primaryForeground",
          "hoverOpacity": 0.9
        },
        "destructive": {
          "background": "destructive",
          "foreground": "destructiveForeground",
          "hoverOpacity": 0.9
        },
        "outline": {
          "background": "transparent",
          "border": "border",
          "foreground": "foreground",
          "hoverBackground": "accent"
        },
        "secondary": {
          "background": "secondary",
          "foreground": "secondaryForeground",
          "hoverOpacity": 0.8
        },
        "ghost": {
          "background": "transparent",
          "foreground": "foreground",
          "hoverBackground": "accent"
        },
        "link": {
          "background": "transparent",
          "foreground": "primary",
          "textDecoration": "underline"
        },
        "neon": {
          "background": "transparent",
          "border": "primary",
          "foreground": "primary",
          "glow": "cyan",
          "hoverBackground": "primary/10"
        },
        "cyber": {
          "background": "gradient-neon",
          "foreground": "white",
          "glow": "intense"
        },
        "glass": {
          "background": "white/10",
          "backdropBlur": "12px",
          "border": "white/20",
          "foreground": "white"
        }
      },
      "sizes": {
        "default": { "height": "40px", "paddingX": "16px", "fontSize": "14px" },
        "sm": { "height": "36px", "paddingX": "12px", "fontSize": "14px" },
        "lg": { "height": "44px", "paddingX": "32px", "fontSize": "14px" },
        "xl": { "height": "56px", "paddingX": "48px", "fontSize": "18px" },
        "icon": { "height": "40px", "width": "40px" }
      },
      "borderRadius": "0.75rem"
    },
    "card": {
      "background": "card",
      "foreground": "cardForeground",
      "border": "border",
      "borderRadius": "0.75rem",
      "shadow": "sm",
      "padding": "24px"
    },
    "input": {
      "background": "background",
      "border": "input",
      "foreground": "foreground",
      "placeholder": "mutedForeground",
      "borderRadius": "0.75rem",
      "height": "40px",
      "paddingX": "12px",
      "focusRing": "ring"
    },
    "badge": {
      "variants": {
        "default": { "background": "primary", "foreground": "primaryForeground" },
        "secondary": { "background": "secondary", "foreground": "secondaryForeground" },
        "destructive": { "background": "destructive", "foreground": "destructiveForeground" },
        "outline": { "background": "transparent", "border": "border", "foreground": "foreground" }
      },
      "borderRadius": "9999px",
      "paddingX": "10px",
      "paddingY": "2px",
      "fontSize": "12px"
    }
  },

  "figmaImportNotes": {
    "colorFormat": "Use HSL values for Figma variables. Hex provided for manual entry.",
    "fontSetup": "Import Space Grotesk and JetBrains Mono from Google Fonts before applying styles.",
    "spacingGrid": "Use 4px base grid (spacing values are multiples of 4px).",
    "radiusVariable": "Create a --radius variable set to 12px (0.75rem) as the base.",
    "themeSetup": "Create two color modes: Light and Dark. Apply semantic tokens to both.",
    "componentStructure": "Build components with Auto Layout matching the padding/spacing tokens."
  }
}
