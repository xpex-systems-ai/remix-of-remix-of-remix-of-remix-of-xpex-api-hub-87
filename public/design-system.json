  "typography": {
    "fontFamilies": {
      "sans": {
        "name": "Space Grotesk",
        "fallback": "sans-serif",
        "googleFonts": "https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap",
        "usage": "Headings, body text, UI elements"
      },
      "mono": {
        "name": "JetBrains Mono",
        "fallback": "monospace",
        "googleFonts": "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap",
        "usage": "Code blocks, API keys, technical data"
      }
    },
    "fontSizes": {
      "xs": { "value": "0.75rem", "px": "12px", "lineHeight": "1rem" },
      "sm": { "value": "0.875rem", "px": "14px", "lineHeight": "1.25rem" },
      "base": { "value": "1rem", "px": "16px", "lineHeight": "1.5rem" },
      "lg": { "value": "1.125rem", "px": "18px", "lineHeight": "1.75rem" },
      "xl": { "value": "1.25rem", "px": "20px", "lineHeight": "1.75rem" },
      "2xl": { "value": "1.5rem", "px": "24px", "lineHeight": "2rem" },
      "3xl": { "value": "1.875rem", "px": "30px", "lineHeight": "2.25rem" },
      "4xl": { "value": "2.25rem", "px": "36px", "lineHeight": "2.5rem" },
      "5xl": { "value": "3rem", "px": "48px", "lineHeight": "1" },
      "6xl": { "value": "3.75rem", "px": "60px", "lineHeight": "1" },
      "7xl": { "value": "4.5rem", "px": "72px", "lineHeight": "1" }
    },
    "fontWeights": {
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "letterSpacing": {
      "tighter": "-0.05em",
      "tight": "-0.025em",
      "normal": "0em",
      "wide": "0.025em",
      "wider": "0.05em",
      "widest": "0.1em"
    },
    "textStyles": {
      "h1": {
        "fontFamily": "Space Grotesk",
        "fontSize": "3rem",
        "fontWeight": 700,
        "lineHeight": 1,
        "letterSpacing": "-0.025em"
      },
      "h2": {
        "fontFamily": "Space Grotesk",
        "fontSize": "2.25rem",
        "fontWeight": 600,
        "lineHeight": 1.2,
        "letterSpacing": "-0.025em"
      },
      "h3": {
        "fontFamily": "Space Grotesk",
        "fontSize": "1.5rem",
        "fontWeight": 600,
        "lineHeight": 1.3
      },
      "h4": {
        "fontFamily": "Space Grotesk",
        "fontSize": "1.25rem",
        "fontWeight": 500,
        "lineHeight": 1.4
      },
      "body": {
        "fontFamily": "Space Grotesk",
        "fontSize": "1rem",
        "fontWeight": 400,
        "lineHeight": 1.5
      },
      "bodySmall": {
        "fontFamily": "Space Grotesk",
        "fontSize": "0.875rem",
        "fontWeight": 400,
        "lineHeight": 1.4
      },
      "caption": {
        "fontFamily": "Space Grotesk",
        "fontSize": "0.75rem",
        "fontWeight": 400,
        "lineHeight": 1.3
      },
      "code": {
        "fontFamily": "JetBrains Mono",
        "fontSize": "0.875rem",
        "fontWeight": 400,
        "lineHeight": 1.6
      }
    }
